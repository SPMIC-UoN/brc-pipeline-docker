# Install ONHARMONY-UKB pipeline

#RUN cd /usr/local && \
#    git clone https://github.com/SPMIC-UoN/ON-Harmony_UKBB_pipeline && \
#    cd ON-Harmony_UKBB_pipeline && \
#    git checkout ON-Harmony && \
#    /opt/conda/envs/ukbb/bin/pip install -r requirements.txt && \
#    sed -i -e 's/eddy_cuda/eddy/g' /usr/local/ON-Harmony_UKBB_pipeline/bb_diffusion_pipeline/bb_eddy/bb_eddy_wrap

COPY _deps/ON-Harmony_UKBB_pipeline /usr/local/ON-Harmony_UKBB_pipeline/
RUN cd /usr/local/ON-Harmony_UKBB_pipeline && \
    /opt/conda/envs/ukbb/bin/pip install -r requirements.txt
    
ENV BBDIR=/usr/local/ON-Harmony_UKBB_pipeline \
    BB_BIN_DIR=/usr/local/ON-Harmony_UKBB_pipeline \
    MNI=$FSLDIR/data/standard/MNI152_T1_1mm.nii.gz \
    MNI_mask=$FSLDIR/data/standard/MNI152_T1_1mm_brain_mask.nii.gz \
    MNI_brain=$FSLDIR/data/standard/MNI152_T1_1mm_brain.nii.gz \
    MNI_dir=$FSLDIR/data/standard 

ENV FSLGPUDIR=$BB_BIN_DIR/bb_diffusion_pipeline/bedpostx \
    PYTHONPATH=$BB_BIN_DIR:$PYTHONPATH \
    templ=$BB_BIN_DIR/templates \
    PATH=$BB_BIN_DIR/bb_pipeline_tools:$BB_BIN_DIR/bb_general_tools:$PATH \
    USER=root


